{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://web-clip-helper.dev/schemas/list-result.schema.json",
  "title": "ListResult",
  "description": "JSONL result output for the `list` command (type=result, stage=list).",
  "type": "object",
  "required": ["type", "stage", "id", "url", "title", "source_type", "category", "tags", "folder_path", "markdown_path", "image_count", "is_dynamic", "refresh_interval_days", "created_at", "updated_at"],
  "properties": {
    "type": {
      "type": "string",
      "const": "result",
      "description": "JSONL message type."
    },
    "stage": {
      "type": "string",
      "const": "list",
      "description": "Command stage identifier."
    },
    "id": {
      "type": "integer",
      "minimum": 1,
      "description": "Clip record ID."
    },
    "url": {
      "type": ["string", "null"],
      "description": "Original clipped URL."
    },
    "title": {
      "type": "string",
      "description": "Clip title."
    },
    "source_type": {
      "type": "string",
      "description": "Adapter source type."
    },
    "category": {
      "type": "string",
      "description": "LLM-generated category."
    },
    "tags": {
      "description": "Tags as a JSON array or JSON-encoded string depending on storage.",
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "string"
        }
      ]
    },
    "folder_path": {
      "type": "string",
      "description": "Absolute path to the clip storage folder."
    },
    "markdown_path": {
      "type": "string",
      "description": "Absolute path to the Markdown file."
    },
    "image_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of downloaded images."
    },
    "is_dynamic": {
      "type": "integer",
      "enum": [0, 1],
      "description": "Dynamic refresh flag."
    },
    "refresh_interval_days": {
      "type": "integer",
      "minimum": 1,
      "description": "Refresh interval in days."
    },
    "last_refreshed_at": {
      "type": ["string", "null"],
      "description": "ISO 8601 timestamp of last refresh, or null."
    },
    "created_at": {
      "type": "string",
      "description": "ISO 8601 creation timestamp."
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 last-update timestamp."
    }
  },
  "additionalProperties": false
}
